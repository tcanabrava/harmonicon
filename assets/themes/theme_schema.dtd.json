{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "harmonicon/theme",
  "title": "Harmonicon Theme",
  "description": "Visual theme for menus, gameplay screens, and UI elements.",
  "type": "object",
  "required": ["name", "description", "default_menu_button", "default_background", "menus"],
  "additionalProperties": false,

  "$defs": {
    "image_with_shader": {
      "type": "object",
      "required": ["image_file"],
      "additionalProperties": false,
      "properties": {
        "image_file":  { "type": "string", "description": "Path relative to the theme directory." },
        "description": { "type": "string" },
        "shader":      { "type": "string", "description": "Path to a GLSL shader applied to this image." }
      }
    },

    "state_shaders": {
      "description": "Per-interaction-state shader paths (WGSL, relative to the theme directory).",
      "type": "object",
      "required": ["hover", "click", "idle"],
      "additionalProperties": false,
      "properties": {
        "hover": { "type": "string" },
        "click": { "type": "string" },
        "idle":  { "type": "string" }
      }
    },

    "state_sounds": {
      "description": "Per-interaction-state audio cue paths (relative to the theme directory).",
      "type": "object",
      "required": ["hover", "click"],
      "additionalProperties": false,
      "properties": {
        "hover": { "type": "string" },
        "click": { "type": "string" }
      }
    },

    "coords": {
      "description": "Absolute position and size in pixels for a UI element.",
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "additionalProperties": false,
      "properties": {
        "x":      { "type": "number" },
        "y":      { "type": "number" },
        "width":  { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 }
      }
    },

    "button_def": {
      "description": "Appearance of a single button.  Used both for default_menu_button and for per-menu button overrides.  All fields are optional so a per-menu entry only needs to specify what differs from the default.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "description": "Button identifier.  Must match a MenuButton enum variant name (e.g. Play, BackToMain).  Required for per-menu buttons; omitted on default_menu_button."
        },
        "description":      { "type": "string" },
        "background_image": { "$ref": "#/$defs/image_with_shader" },
        "icon": {
          "type": "object",
          "required": ["image_file"],
          "additionalProperties": false,
          "properties": {
            "image_file":  { "type": "string" },
            "description": { "type": "string" },
            "shaders":     { "$ref": "#/$defs/state_shaders" }
          }
        },
        "button_shaders": { "$ref": "#/$defs/state_shaders" },
        "button_sounds":  { "$ref": "#/$defs/state_sounds" },
        "coords":         { "$ref": "#/$defs/coords" }
      }
    },

    "menu_def": {
      "description": "One named menu screen.  Both background_image and buttons are optional: a screen can have only a background (e.g. Credits), only buttons (e.g. ArtistList), or both.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "background_image": {
          "type": "string",
          "description": "Path to the background image for this menu screen, relative to the theme directory."
        },
        "buttons": {
          "type": "array",
          "description": "Ordered list of buttons with fixed pixel positions on this screen.",
          "items": { "$ref": "#/$defs/button_def" }
        }
      }
    }
  },

  "properties": {
    "name": {
      "type": "string",
      "description": "Human-readable name of the theme shown in the theme picker."
    },

    "description": {
      "type": "string",
      "description": "Short description of the theme."
    },

    "default_menu_button": {
      "description": "Fallback button appearance used when a per-menu button entry omits a field.",
      "$ref": "#/$defs/button_def"
    },

    "default_background": {
      "description": "Fallback background used by any screen that does not define its own.",
      "type": "object",
      "required": ["image"],
      "additionalProperties": false,
      "properties": {
        "image":       { "type": "string" },
        "description": { "type": "string" }
      }
    },

    "menus": {
      "description": "Named menu screens.  Keys are menu identifiers (Main, Play, Options, …).",
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/menu_def" }
    },

    "colors": {
      "description": "Theme colors.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "song_editor": {
          "description": "Colors for the song editor.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "editor_bg": {
              "description": "Background color for the song editor.",
              "type": "string"
            },
            "hole_box": {
              "description": "Background color for the hole box in the song editor.",
              "type": "string"
            },
            "lane_a": {
              "description": "",
              "type": "string"
            },
            "lane_b": {
              "description": "",
              "type": "string"
            },
            "grid_line": {
              "description": "",
              "type": "string"
            },
            "bar_line": {
              "description": "",
              "type": "string"
            },
            "half_line": {
              "description": "",
              "type": "string"
            },
            "quarter_line": {
              "description": "",
              "type": "string"
            },
            "accent": {
              "description": "",
              "type": "string"
            },
            "label": {
              "description": "",
              "type": "string"
            },
            "panel_bg": {
              "description": "",
              "type": "string"
            },
            "btn_bg": {
              "description": "",
              "type": "string"
            },
            "btn_active": {
              "description": "",
              "type": "string"
            },
            "field_bg": {
              "description": "",
              "type": "string"
            },
            "field_bg_focus": {
              "description": "",
              "type": "string"
            },
            "ghost_ok": {
              "description": "",
              "type": "string"
            },
            "ghost_bad": {
              "description": "",
              "type": "string"
            }
          }
        },
        "twelve_bar": {
          "description": "Chord-function colors (I/IV/V) for a 12-bar blues progression, shared by the Jam Session bar grid and the song editor's grid background.",
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "tonic": {
              "description": "I (tonic) — the \"home\" chord most bars sit on.",
              "type": "string"
            },
            "subdominant": {
              "description": "IV (subdominant).",
              "type": "string"
            },
            "dominant": {
              "description": "V (dominant).",
              "type": "string"
            }
          }
        }
      }
    }
  }
}
