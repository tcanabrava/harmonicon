    { "id": "slide_repeat_c", "time": 7.0, "duration": 0.75,
      "events": [{ "hole": 6, "action": "blow", "note": "G5" }] },

    { "id": "bend_in", "time": 9.5, "duration": 1.5, "phrase": "Bend and release: 2 draw",
