    "description": "Lesson drill: an adjacent-hole slide run (holes 4-5-6 blow), then a half-step draw bend released back to the natural note, on a C diatonic. Original technique exercise, no melody."
  },
  "song": {
    "title": "Slides Drill",
    "artist": "Harmonicon Lessons",
    "tempo_bpm": 76,
    "key": "C",
    "time_signature": "4/4",
    "difficulty": "easy"
  },
  "timing": {
    "resolution": 480,
    "tempo_map": [ { "tick": 0, "bpm": 76 } ]
  },
  "harmonica": {
    "type": "diatonic",
    "holes": 10,
    "position": "1st",
    "bending_profile": "richter_standard",
    "layout": {
      "blow": ["C4","E4","G4","C5","E5","G5","C6","E6","G6","C7"],
      "draw": ["D4","G4","B4","D5","F5","A5","B5","D6","F6","A6"]
    }
  },
  "track": [
    { "id": "slide_a", "time": 2.0, "duration": 0.75, "phrase": "Hole slide: 4-5-6 blow",
      "events": [{ "hole": 4, "action": "blow", "note": "C5" }] },
    { "id": "slide_b", "time": 2.75, "duration": 0.75,
      "events": [{ "hole": 5, "action": "blow", "note": "E5" }] },
    { "id": "slide_c", "time": 3.5, "duration": 0.75,
      "events": [{ "hole": 6, "action": "blow", "note": "G5" }] },
    { "id": "slide_repeat_a", "time": 5.5, "duration": 0.75,
      "events": [{ "hole": 4, "action": "blow", "note": "C5" }] },
    { "id": "slide_repeat_b", "time": 6.25, "duration": 0.75,
