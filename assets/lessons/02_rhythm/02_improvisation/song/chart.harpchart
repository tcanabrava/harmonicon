    "description": "Lesson drill: an open Jam Session, C harmonica in 2nd position (key of G) over a 12-bar blues cycle. Judged live by scale/chord-tone adherence, not by a fixed set of notes — there is no melody to transcribe, original or otherwise."
  },
  "song": {
    "title": "Improvisation Drill",
    "artist": "Harmonicon Lessons",
    "tempo_bpm": 80,
    "key": "G",
    "time_signature": "4/4",
    "difficulty": "easy"
  },
  "timing": {
    "resolution": 480,
    "tempo_map": [ { "tick": 0, "bpm": 80 } ]
  },
  "harmonica": {
    "type": "diatonic",
    "holes": 10,
    "position": "2nd",
    "bending_profile": "richter_standard",
    "layout": {
      "blow": ["C4","E4","G4","C5","E5","G5","C6","E6","G6","C7"],
      "draw": ["D4","G4","B4","D5","F5","A5","B5","D6","F6","A6"]
    }
  },
  "track": [
    { "id": "jam_marker", "time": 0.0, "duration": 36.0,
