{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/harpchart.schema.json",
  "title": "HarpChart v1.0",
  "description": "Schema for harmonica rhythm game charts.",
  "type": "object",
  "required": ["song", "harmonica", "timing", "track", "scoring"],
  "additionalProperties": false,

  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "author": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "description": "Original song title or source material."
        },
        "license": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "audio_file": {
          "type": "string",
          "description": "Song Editor round-trip only — the backing-track filename shown/edited in its metadata form. Gameplay always loads song/*.ogg by convention regardless of this field."
        }
      }
    },

    "song": {
      "type": "object",
      "required": [
        "title",
        "artist",
        "tempo_bpm",
        "key",
        "difficulty"
      ],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "artist": {
          "type": "string"
        },
        "tempo_bpm": {
          "type": "number",
          "minimum": 20,
          "maximum": 300
        },
        "key": {
          "type": "string"
        },
        "time_signature": {
          "type": "string",
          "pattern": "^[0-9]+/[0-9]+$",
          "description": "Informational default. When timing.time_signature_map is present it takes precedence."
        },
        "difficulty": {
          "type": "string",
          "enum": [
            "easy",
            "intermediate",
            "advanced",
            "expert"
          ]
        },
        "feel": {
          "type": "string",
          "enum": [
            "straight",
            "shuffle"
          ],
          "description": "Metronome click subdivision this song is written for. Optional — omitting it leaves the player's current metronome feel choice untouched."
        }
      }
    },

    "timing": {
      "type": "object",
      "required": ["resolution", "tempo_map"],
      "additionalProperties": false,
      "properties": {
        "resolution": {
          "type": "integer",
          "minimum": 1,
          "description": "Ticks per quarter note."
        },

        "tempo_map": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["tick", "bpm"],
            "additionalProperties": false,
            "properties": {
              "tick": {
                "type": "integer",
                "minimum": 0
              },
              "bpm": {
                "type": "number",
                "minimum": 20,
                "maximum": 300
              }
            }
          }
        },

        "time_signature_map": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["tick", "time_signature"],
            "additionalProperties": false,
            "properties": {
              "tick": {
                "type": "integer",
                "minimum": 0
              },
              "time_signature": {
                "type": "string",
                "pattern": "^[0-9]+/[0-9]+$"
              }
            }
          }
        }
      }
    },

    "harmonica": {
      "type": "object",
      "required": ["type", "holes"],
      "unevaluatedProperties": false,

      "properties": {
        "type": {
          "type": "string",
          "enum": ["diatonic", "chromatic"]
        },

        "holes": {
          "type": "integer",
          "minimum": 1
        },

        "position": {
          "type": "string"
        },

        "scale": {
          "type": "string",
          "enum": [
            "first_position",
            "second_position",
            "third_position",
            "major",
            "minor_pentatonic",
            "country"
          ],
          "description": "Which scale the Song Editor colors notes against. first_position/second_position/third_position all use the blues scale, rooted at the harp's own key/a 5th up/a whole step up respectively; the others are the named scale rooted on the harp's own key. Optional, defaults to first_position."
        }
      },

      "if": {
        "properties": {
          "type": {
            "const": "diatonic"
          }
        }
      },

      "then": {
        "required": ["bending_profile"],

        "properties": {
          "holes": {
            "const": 10
          },

          "bending_profile": {
            "type": "string",
            "enum": [
              "richter_standard",
              "country_tuned"
            ]
          },

          "layout": {
            "type": "object",
            "additionalProperties": false,

            "properties": {
              "blow": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 10,
                "maxItems": 10
              },

              "draw": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "minItems": 10,
                "maxItems": 10
              }
            }
          }
        }
      },

      "else": {
        "properties": {
          "holes": {
            "type": "integer",
            "enum": [10, 12, 16]
          },

          "layout": {
            "type": "object",
            "additionalProperties": false,

            "properties": {
              "blow": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },

              "draw": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },

              "blow_slide": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },

              "draw_slide": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },

    "track": {
      "type": "array",
      "minItems": 1,

      "items": {
        "type": "object",

        "required": [
          "duration",
          "events"
        ],

        "additionalProperties": false,

        "properties": {
          "id": {
            "type": "string",
            "description": "Human-readable label for debugging and log output."
          },

          "time": {
            "type": "number",
            "minimum": 0
          },

          "tick": {
            "type": "integer",
            "minimum": 0
          },

          "duration": {
            "type": "number",
            "exclusiveMinimum": 0
          },

          "phrase": {
            "type": "string"
          },

          "groove": {
            "type": "string"
          },

          "play_mode": {
            "type": "string",
            "enum": [
              "single",
              "chord",
              "split"
            ]
          },

          "call": {
            "type": "boolean",
            "description": "Marks this item as part of a call-and-response phrase. Before a maximal run of consecutive call:true items, the game synthesizes and plays their notes as a one-shot audio demo, then always waits for the player to echo them. Absent = false, an ordinary item."
          },

          "events": {
            "type": "array",
            "minItems": 1,

            "items": {
              "type": "object",

              "required": [
                "hole",
                "action"
              ],

              "additionalProperties": false,

              "properties": {
                "hole": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Must not exceed harmonica.holes. This is validated by the engine."
                },

                "action": {
                  "type": "string",
                  "enum": [
                    "blow",
                    "draw"
                  ]
                },

                "note": {
                  "type": "string",
                  "pattern": "^[A-G][#b]?[0-9]$"
                },

                "modifiers": {
                  "type": "array",

                  "minItems": 1,
                  "maxItems": 2,
                  "uniqueItems": true,

                  "description": "Modifier compatibility is validated by the engine.",

                  "items": {
                    "type": "object",

                    "required": ["type"],

                    "unevaluatedProperties": false,

                    "properties": {
                      "type": {
                        "type": "string",

                        "enum": [
                          "bend",
                          "overblow",
                          "overdraw",
                          "slide",
                          "vibrato",
                          "wah-wah"
                        ]
                      }
                    },

                    "oneOf": [
                      {
                        "properties": {
                          "type": {
                            "const": "bend"
                          },

                          "semitones": {
                            "type": "number",
                            "minimum": -3,
                            "exclusiveMaximum": 0
                          },

                          "intensity": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },

                        "required": [
                          "semitones"
                        ]
                      },

                      {
                        "properties": {
                          "type": {
                            "const": "overblow"
                          }
                        }
                      },

                      {
                        "properties": {
                          "type": {
                            "const": "overdraw"
                          }
                        }
                      },

                      {
                        "properties": {
                          "type": {
                            "const": "slide"
                          }
                        }
                      },

                      {
                        "properties": {
                          "type": {
                            "const": "vibrato"
                          },

                          "oscillation_hz": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          },

                          "intensity": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },

                        "required": [
                          "oscillation_hz"
                        ]
                      },

                      {
                        "properties": {
                          "type": {
                            "const": "wah-wah"
                          },

                          "oscillation_hz": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          },

                          "intensity": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },

                        "required": [
                          "oscillation_hz"
                        ]
                      }
                    ]
                  }
                }
              }
            }
          }
        },

        "oneOf": [
          {
            "required": ["time"]
          },

          {
            "required": ["tick"]
          }
        ]
      }
    },

    "loop": {
      "type": "object",

      "required": [
        "start_index",
        "end_index"
      ],

      "additionalProperties": false,

      "properties": {
        "type": {
          "type": "string",

          "enum": [
            "intro",
            "verse",
            "chorus",
            "bridge",
            "outro",
            "full"
          ]
        },

        "repeat": {
          "type": "boolean"
        },

        "start_index": {
          "type": "integer",
          "minimum": 0
        },

        "end_index": {
          "type": "integer",
          "minimum": 0
        }
      }
    },

    "scoring": {
      "type": "object",

      "required": [
        "perfect_window_ms",
        "good_window_ms",
        "miss_window_ms"
      ],

      "additionalProperties": false,

      "properties": {
        "perfect_window_ms": {
          "type": "integer",
          "minimum": 1
        },

        "good_window_ms": {
          "type": "integer",
          "minimum": 1
        },

        "miss_window_ms": {
          "type": "integer",
          "minimum": 1
        },

        "combo": {
          "type": "object",

          "required": [
            "enabled",
            "base_multiplier",
            "step_multiplier",
            "max_multiplier"
          ],

          "additionalProperties": false,

          "properties": {
            "enabled": {
              "type": "boolean"
            },

            "base_multiplier": {
              "type": "number",
              "minimum": 1
            },

            "step_multiplier": {
              "type": "number",
              "exclusiveMinimum": 0
            },

            "max_multiplier": {
              "type": "number",
              "exclusiveMinimum": 1
            },

            "decay_ms": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          }
        },

        "style_bonus": {
          "type": "object",

          "additionalProperties": {
            "type": "number"
          }
        }
      }
    }
  }
}
